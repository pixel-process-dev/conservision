from PIL import Image
from collections import Counter
import os


def get_jpg_dimensions(file_paths):
    """
    Reads the dimensions of each JPEG file in a list and returns a count 
    of the unique dimensions.

    Args:
        file_paths (list): A list of file paths to the JPEG images.

    Returns:
        dict: A dictionary where keys are dimension tuples (width, height) 
              and values are their counts.
    """
    dimensions_list = []
    for file_path in file_paths:
        try:
            # Open the image using Pillow (PIL)
            with Image.open(file_path) as img:
                # The .size property returns a tuple (width, height)
                dimensions = img.size
                dimensions_list.append(dimensions)
        except IOError:
            # Handle cases where the file might not be a valid image or doesn't exist
            print(f"Error reading image: {file_path}")
            continue

    # Use Counter to count occurrences of each dimension
    dimension_counts = Counter(dimensions_list)
    return dimension_counts



from glob import glob


image_files = glob('../data/competition/crops/train/*jpg')
print(len(image_files))



# 2. Get the dimension counts
counts = get_jpg_dimensions(image_files)

# 3. Print the results
print("Dimension Counts:")
for dimensions, count in counts.items():
    print(f"  {dimensions[0]}x{dimensions[1]} (WxH): {count}")





